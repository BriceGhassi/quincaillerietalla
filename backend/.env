# ═══════════════════════════════════════════════════════════
# .env — Variables d'environnement / Environment variables
# COPIEZ CE FICHIER en .env et remplissez vos valeurs
# COPY THIS FILE to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# Serveur / Server
PORT=5000
NODE_ENV=development

# Base de données MySQL / MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=quincaillerie_db
DB_USER=root
DB_PASSWORD=test

# JWT Secret (changez ceci en production! / change this in production!)
JWT_SECRET=quincaillerie_super_secret_jwt_2025_changez_moi
JWT_EXPIRES_IN=8h

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:5173
